<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppLembreteMedicacao.Views.CadastroUsuario"
             Title="Criar Conta"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="18" VerticalOptions="Start">

            <!-- Título -->
            <Label Text="Criar Conta"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2563EB"
                   HorizontalOptions="Center"
                   Margin="0,10,0,10"/>

            <!-- Campo Nome -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" Padding="15,0" BackgroundColor="#F8FAFC">
                <Entry x:Name="txtNome"
                       Placeholder="Primeiro Nome"
                       TextColor="#1E293B"
                       PlaceholderColor="#94A3B8"
                       HeightRequest="55" />
            </Border>

            <!-- Campo Sobrenome -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" Padding="15,0" BackgroundColor="#F8FAFC">
                <Entry x:Name="txtSobrenome"
                       Placeholder="Sobrenome"
                       TextColor="#1E293B"
                       PlaceholderColor="#94A3B8"
                       HeightRequest="55" />
            </Border>

            <!-- Email -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" Padding="15,0" BackgroundColor="#F8FAFC">
                <Entry x:Name="txtEmail"
                       Placeholder="E-mail"
                       Keyboard="Email"
                       TextColor="#1E293B"
                       PlaceholderColor="#94A3B8"
                       HeightRequest="55" />
            </Border>

            <!-- Senha -->
            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" Padding="15,0" BackgroundColor="#F8FAFC">
                <Entry x:Name="txtSenha"
                       Placeholder="Crie uma senha"
                       IsPassword="True"
                       TextColor="#1E293B"
                       PlaceholderColor="#94A3B8"
                       HeightRequest="55" />
            </Border>

            <!-- Perfil (Tipo de Usuário) -->
            <Label Text="Selecione seu Perfil:" TextColor="#64748B" Margin="5,5,0,0" FontSize="14" />
            <Border StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" Padding="15,0" BackgroundColor="#F8FAFC">
                <Picker x:Name="pickerPerfil"
                        Title="Tipo de Perfil"
                        TitleColor="#94A3B8"
                        TextColor="#1E293B"
                        HeightRequest="55">
                    <Picker.Items>
                        <x:String>Paciente</x:String>
                        <x:String>Responsável</x:String>
                        <x:String>Médico</x:String>
                    </Picker.Items>
                </Picker>
            </Border>

            <!-- Botão Salvar -->
            <Button Text="Finalizar Cadastro"
                    Clicked="OnSalvarClicked"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="55"
                    Margin="0,15,0,0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="2" Opacity="0.1"/>
                </Button.Shadow>
            </Button>

            <!-- Voltar ao Login -->
            <Button Text="Já sou cadastrado"
                    Clicked="OnLoginClicked"
                    BackgroundColor="Transparent"
                    TextColor="#2563EB"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="45"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppLembreteMedicacao.Views.Novomedicacao"
             Title="Nova Medicação"
             BackgroundColor="White">

    <ScrollView>

        <VerticalStackLayout Padding="30"
                             Spacing="15">

            <!-- TÍTULO -->
            <Label Text="Nova Medicação"
                   FontSize="24"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="#0056b3" />

            <!-- TEXTO AUXILIAR -->
            <Label Text="Cadastre um novo medicamento"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray" />

            <!-- NOME -->
            <Label Text="Nome do Remédio"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#0056b3" />

            <Frame BorderColor="#0056b3"
                   CornerRadius="10"
                   Padding="10"
                   BackgroundColor="White">

                <Entry x:Name="txtNome"
                       Placeholder="Ex: Dipirona"
                       PlaceholderColor="Gray"
                       TextColor="#333333"
                       BackgroundColor="Transparent"/>

            </Frame>

            <!-- DOSAGEM -->
            <Label Text="Dosagem"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#0056b3" />

            <Frame BorderColor="#0056b3"
                   CornerRadius="10"
                   Padding="10"
                   BackgroundColor="White">

                <Entry x:Name="txtDosagem"
                       Placeholder="Ex: 500mg"
                       PlaceholderColor="Gray"
                       TextColor="#333333"
                       BackgroundColor="Transparent"/>

            </Frame>

            <!-- INTERVALO -->
            <Label Text="Intervalo (em horas)"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#0056b3" />

            <Frame BorderColor="#0056b3"
                   CornerRadius="10"
                   Padding="10"
                   BackgroundColor="White">

                <Entry x:Name="txtIntervalo"
                       Placeholder="Ex: 8"
                       Keyboard="Numeric"
                       PlaceholderColor="Gray"
                       TextColor="#333333"
                       BackgroundColor="Transparent"/>

            </Frame>

            <!-- BOTÃO SALVAR -->
            <Button Text="Agendar e Salvar"
                    Clicked="OnSalvarClicked"
                    BackgroundColor="#0056b3"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,20,0,0" />

            <!-- BOTÃO HISTÓRICO -->
            <Button Text="Ver Histórico"
                    Clicked="OnMonitoramentoClicked"
                    BackgroundColor="#5271ff"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50" />

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>
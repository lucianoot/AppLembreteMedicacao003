<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppLembreteMedicacao.Views.Novomedicacao"
             Title="Novomedicacao">
    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="Nova Medicação" 
           FontSize="24" 
           HorizontalOptions="Center" 
           FontAttributes="Bold" />

        <Label Text="Nome do Remédio:" />
        <Entry x:Name="txtNome" 
           Placeholder="Ex: Dipirona" />

        <Label Text="Dosagem:" />
        <Entry x:Name="txtDosagem" 
           Placeholder="Ex: 500mg" />

        <Label Text="Intervalo (em horas):" />
        <Entry x:Name="txtIntervalo" 
           Placeholder="Ex: 8" 
           Keyboard="Numeric" />

        <Button Text="Agendar e Salvar"
            Clicked="OnSalvarClicked"
            BackgroundColor="#512BD4"
            TextColor="White"
            Margin="0,20,0,0" />
        
        <Button Text="Ver Histórico"
        Clicked="OnMonitoramentoClicked"
        BackgroundColor="#2563EB"
        TextColor="White"
        CornerRadius="10"/>

    </VerticalStackLayout>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppLembreteMedicacao.Views.Monitoramento"
             Title="Monitoramento"
             BackgroundColor="White">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sair" Clicked="OnSairClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <!-- TÍTULO -->
            <Label Text="RELATÓRIO DE ADESÃO"
                   FontSize="14"
                   CharacterSpacing="2"
                   FontAttributes="Bold"
                   TextColor="Gray"
                   HorizontalOptions="Center" />

            <Label x:Name="lblNomePaciente"
                   Text="Carregando..."
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#0056b3"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <BoxView HeightRequest="1"
                     Color="#E0E0E0"
                     Margin="0,5" />

            <!-- ADESÃO -->
            <Label Text="Adesão por Medicamento"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#0056b3" />

            <CollectionView x:Name="listaEstatisticas"
                            HeightRequest="130">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"
                                       ItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Frame WidthRequest="170"
                               Padding="12"
                               CornerRadius="10"
                               BackgroundColor="White"
                               BorderColor="#0056b3">

                            <VerticalStackLayout Spacing="4">

                                <Label Text="{Binding Nome}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="#333333"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding Percentual, StringFormat='{0:P0} Adesão'}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#0056b3" />

                                <ProgressBar Progress="{Binding Percentual}"
                                             ProgressColor="#0056b3"
                                             HeightRequest="8" />

                                <Label Text="{Binding Tomadas, StringFormat='{0} tomadas'}"
                                       FontSize="11"
                                       TextColor="Gray" />

                                <Label Text="{Binding Total, StringFormat='de {0} registros'}"
                                       FontSize="11"
                                       TextColor="Gray" />

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1"
                     Color="#E0E0E0"
                     Margin="0,10" />

            <!-- HISTÓRICO -->
            <Label Text="Histórico Detalhado"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#0056b3" />

            <CollectionView x:Name="listaHistorico">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame Margin="0,5"
                               Padding="12"
                               CornerRadius="10"
                               BackgroundColor="White"
                               BorderColor="#0056b3">

                            <VerticalStackLayout Spacing="3">

                                <Label Text="{Binding NomeMedicamento}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       TextColor="#333333"/>

                                <Label Text="{Binding DataUso}"
                                       FontSize="12"
                                       TextColor="Gray" />

                                <Label Text="{Binding TomadoTexto}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="{Binding CorStatus}"/>

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
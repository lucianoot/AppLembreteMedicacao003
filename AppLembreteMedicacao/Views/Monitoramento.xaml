<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppLembreteMedicacao.Views.Monitoramento"
             Title="Monitoramento"
             BackgroundColor="White">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Sair" Clicked="OnSairClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Label Text="RELATÓRIO DE ADESÃO"
                   FontSize="14"
                   CharacterSpacing="2"
                   FontAttributes="Bold"
                   TextColor="Gray"
                   HorizontalOptions="Center" />

            <Label x:Name="lblNomePaciente"
                   Text="Carregando..."
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#0056b3"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <BoxView HeightRequest="1"
                     Color="#E0E0E0"
                     Margin="0,5" />

            <Label Text="Adesão por Medicamento"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#0056b3"
                   Margin="0,10,0,0" />

            <Label Text="Acompanhe o desempenho do seu tratamento abaixo:"
                   FontSize="13"
                   TextColor="Gray"
                   Margin="0,0,0,10" />

            <CollectionView x:Name="listaEstatisticas"
                            HeightRequest="150">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"
                                       ItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame WidthRequest="180"
                               Padding="15"
                               CornerRadius="15"
                               BackgroundColor="White"
                               BorderColor="#0056b3"
                               HasShadow="True">

                            <VerticalStackLayout Spacing="6">

                                <Label Text="{Binding Nome}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="#333333"
                                       LineBreakMode="TailTruncation" />

                                <Label Text="{Binding Percentual, StringFormat='{0:P0} Tomado'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0056b3" />

                                <ProgressBar Progress="{Binding Percentual}"
                                             ProgressColor="#28A745" 
                                             HeightRequest="10" />

                                <Label Text="{Binding Tomadas, StringFormat='{0} tomadas'}"
                                       FontSize="12"
                                       TextColor="#555555" />

                                <Label Text="{Binding Total, StringFormat='de {0} agendados'}"
                                       FontSize="11"
                                       TextColor="Gray" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="20" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppLembreteMedicacao.Views.CronogramaPage"
             Title="Cronograma">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label Text="Cronograma do Remédio" 
                   FontSize="24" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold" 
                   TextColor="#6A0DAD" />

            <CollectionView x:Name="listaCronogramas" 
                            EmptyView="Nenhum horário definido.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#6A0DAD" CornerRadius="10" Margin="0,5" Padding="10">
                            <Grid ColumnDefinitions="*, *, Auto">
                                <Label Grid.Column="0" 
                                       Text="{Binding Hora, StringFormat='🕒 {0}'}" 
                                       FontSize="18" 
                                       VerticalOptions="Center"/>

                                <Label Grid.Column="1" 
                                       Text="{Binding Frequencia}" 
                                       FontSize="16" 
                                       TextColor="Gray" 
                                       VerticalOptions="Center"/>

                                <Button Grid.Column="2" 
                                        Text="❌" 
                                        TextColor="Red"
                                        BackgroundColor="Transparent" 
                                        Clicked="AoClicarRemoverHorario"
                                        CommandParameter="{Binding Id}"
                                        FontSize="14"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Toque no relógio para adicionar" 
                   FontSize="12" 
                   HorizontalOptions="Center" 
                   TextColor="Gray" />

            <ImageButton x:Name="btnAdicionarHorario"
                         Source="clock.png"
                         WidthRequest="80"
                         HeightRequest="80"
                         BackgroundColor="Transparent"
                         HorizontalOptions="Center"
                         Clicked="AoClicarAdicionarHorario"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
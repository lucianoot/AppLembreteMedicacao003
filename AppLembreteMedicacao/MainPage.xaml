<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppLembreteMedicacao.MainPage"
    Title="Meu Remédio"
    BackgroundColor="White">

<ContentPage.ToolbarItems>
<ToolbarItem Text="Compartilhar Prontuário" 
            Clicked="ToolbarItem_Clicked"
            Order="Primary" />
<ToolbarItem Text="Sair" 
            Clicked="AoClicarSair" 
            Order="Secondary" />
</ContentPage.ToolbarItems>

<Grid>
<ScrollView>

<VerticalStackLayout Padding="30" Spacing="15">


    <!-- Mensagem de Boas-vindas Personalizada -->
    <Label x:Name="lblBoasVindas"
    Text="Bem-vindo!"
    FontSize="20"
    FontAttributes="Bold"
    TextColor="#0056b3" 
    HorizontalOptions="Start"
    Margin="0,0,0,10" />

    <Label Text="Cadastro de Remédio"
            FontSize="24"
            HorizontalOptions="Center"
            FontAttributes="Bold"
            TextColor="#0056b3" />

    <Label Text="Nome do Remédio"
            FontSize="14"
            TextColor="#0056b3"
            FontAttributes="Bold"/>
    <Frame BorderColor="#0056b3" CornerRadius="10" Padding="10" BackgroundColor="White">
        <Entry x:Name="entNome"
                Placeholder="Digite o nome do remédio"
                TextColor="#333333"
                PlaceholderColor="Gray"
                BackgroundColor="Transparent"/>
    </Frame>

    <Label Text="Dosagem"
            FontSize="14"
            TextColor="#0056b3"
            FontAttributes="Bold"/>
    <Frame BorderColor="#0056b3" CornerRadius="10" Padding="10" BackgroundColor="White">
        <Entry x:Name="entDose"
                Placeholder="Ex: 500mg"
                TextColor="#333333"
                PlaceholderColor="Gray"
                BackgroundColor="Transparent"/>
    </Frame>

    <Label Text="Data de Início"
            FontSize="14"
            TextColor="#0056b3"
            FontAttributes="Bold"/>
    <Frame BorderColor="#0056b3" CornerRadius="10" Padding="10" BackgroundColor="White">
        <DatePicker x:Name="dtInicio"
                    Format="dd/MM/yyyy"
                    TextColor="#333333"
                    BackgroundColor="Transparent"/>
    </Frame>
    <HorizontalStackLayout Spacing="10" Margin="5,0">
        <CheckBox x:Name="chkIsContinuo" 
                    Color="#0056b3" 
                    CheckedChanged="OnContinuoCheckedChanged" />
        <Label Text="Medicamento de Uso Contínuo" 
                VerticalOptions="Center" 
                TextColor="#333333"
                FontSize="14"/>
    </HorizontalStackLayout>

    <Label Text="Data Final"
            FontSize="14"
            TextColor="#0056b3"
            FontAttributes="Bold"/>
    <Frame BorderColor="#0056b3" CornerRadius="10" Padding="10" BackgroundColor="White">
        <DatePicker x:Name="dtFim"
                    Format="dd/MM/yyyy"
                    TextColor="#333333"
                    BackgroundColor="Transparent"/>
    </Frame>
    <Button x:Name="btnSalvar"
Text="Salvar Medicamento"
Clicked="AoClicarSalvar"
BackgroundColor="#0056b3"
TextColor="White"
FontAttributes="Bold"
CornerRadius="10"
HeightRequest="50"/>

    <Button Text="Ver Histórico de Doses"
            Clicked="OnVerHistoricoClicked"
            BackgroundColor="#0056b3"
            TextColor="White"
            CornerRadius="10"
            Margin="0,10" />

 

    <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10"/>

    <Label Text="Seus Remédios (Toque para gerenciar):"
            FontAttributes="Bold"
            FontSize="16"
            TextColor="#0056b3"/>

    <CollectionView x:Name="listaMedicamentos"
                    EmptyView="Nenhum remédio cadastrado ainda."
                    SelectionMode="None"
                    Margin="0,0,0,80">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame BorderColor="#0056b3" CornerRadius="10" Margin="0,5" Padding="15" BackgroundColor="White">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMedicamentoTapped" CommandParameter="{Binding .}" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="{Binding Nome}" FontAttributes="Bold" FontSize="18" TextColor="#333333"/>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="{Binding Dosagem}" FontSize="14" TextColor="Gray" />
                                <Label Text="•" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding IntervaloHoras, StringFormat='{0}h/{0}h'}"
                                        FontSize="14" TextColor="#0056b3" FontAttributes="Italic"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="➔" VerticalOptions="Center" TextColor="#0056b3" FontSize="20"/>
                    </Grid>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</VerticalStackLayout>
</ScrollView>

<Button Text="+"
    Clicked="AoClicarNovoRemedio"
    BackgroundColor="#0056b3"
    TextColor="White"
    FontSize="28"
    FontAttributes="Bold"
    HeightRequest="60"
    WidthRequest="60"
    CornerRadius="30"
    HorizontalOptions="End"
    VerticalOptions="End"
    Margin="0,0,25,25"
    Padding="0">
<Button.Shadow>
    <Shadow Brush="Black" Offset="0,3" Radius="3" Opacity="0.2"/>
</Button.Shadow>
</Button>
</Grid>
</ContentPage>